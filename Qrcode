<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>QR Code Driver — My Logistic Group</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <style>
    :root {
      --ink:    #0a0f1e;
      --muted:  #6b7280;
      --line:   #e5e7eb;
      --bg:     #f3f4f6;
      --card:   #ffffff;
      --blue:   #2563eb;
      --red:    #dc2626;
      --green:  #16a34a;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Sora', sans-serif;
      background: var(--bg);
      color: var(--ink);
      padding: 32px 24px 64px;
    }

    /* ── Header schermo ── */
    .screen-header {
      max-width: 900px;
      margin: 0 auto 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .screen-header h1 {
      font-size: 1.4rem;
      font-weight: 700;
    }
    .screen-header p {
      font-size: .83rem;
      color: var(--muted);
      margin-top: 3px;
    }
    .btn-print {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 24px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: 'Sora', sans-serif;
      font-size: .9rem;
      font-weight: 700;
      cursor: pointer;
      transition: opacity .15s;
    }
    .btn-print:hover { opacity: .88; }

    /* ── Stato loading / errore ── */
    .status {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
      padding: 48px 0;
      color: var(--muted);
      font-size: .9rem;
    }
    .spinner {
      width: 32px; height: 32px;
      border: 3px solid var(--line);
      border-top-color: var(--blue);
      border-radius: 50%;
      animation: spin .75s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .err { color: var(--red); }

    /* ── Griglia QR (schermo) ── */
    .grid {
      display: none;
      max-width: 900px;
      margin: 0 auto;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
    }

    .qr-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 24px 16px 20px;
      text-align: center;
      box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }
    .qr-canvas {
      display: flex;
      justify-content: center;
      margin-bottom: 14px;
    }
    .qr-canvas canvas,
    .qr-canvas img { border-radius: 6px; }

    .qr-id {
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .qr-name {
      font-size: .95rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.3;
    }
    .qr-url {
      font-size: .6rem;
      color: var(--muted);
      margin-top: 6px;
      word-break: break-all;
    }

    /* ── STAMPA ── */
    @media print {
      @page { size: A4; margin: 14mm; }

      body {
        background: #fff;
        padding: 0;
      }

      .screen-header { display: none; }
      .status { display: none; }

      .grid {
        display: grid !important;
        max-width: 100%;
        grid-template-columns: repeat(3, 1fr);
        gap: 12mm;
      }

      .qr-card {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 12mm 8mm 10mm;
        break-inside: avoid;
        page-break-inside: avoid;
        box-shadow: none;
      }

      .qr-url { display: none; }
    }
  </style>
</head>
<body>

  <!-- Header schermo -->
  <div class="screen-header">
    <div>
      <div style="font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;">My Logistic Group</div>
      <h1>QR Code Driver</h1>
      <p id="subtitleCount">Caricamento driver in corso…</p>
    </div>
    <button class="btn-print" onclick="window.print()">🖨️ &nbsp;Stampa tutti</button>
  </div>

  <!-- Stato -->
  <div class="status" id="statusBox">
    <div class="spinner"></div>
    <div>Recupero lista driver…</div>
  </div>

  <!-- Griglia -->
  <div class="grid" id="grid"></div>

<script>
// ── Config ────────────────────────────────────────────────────
const API        = 'https://script.google.com/macros/s/AKfycbzpihespHqhVbDgh2A5F-0z0K4_J7qNsjsQU7OzeNKDM8h2vOyI-CyRla0yBkHqSaqJ/exec';
const GIRO_URL   = 'https://mylogisticgroup.github.io/giro/giro.html';

// ── JSONP ─────────────────────────────────────────────────────
function apiCall(qs) {
  return new Promise((resolve, reject) => {
    const cb    = '_cb' + Date.now() + Math.random().toString(36).slice(2);
    const tag   = document.createElement('script');
    const timer = setTimeout(() => { delete window[cb]; tag.remove(); reject(new Error('Timeout')); }, 18000);
    window[cb]  = data => { clearTimeout(timer); delete window[cb]; tag.remove(); resolve(data); };
    tag.src     = API + '?' + qs + '&callback=' + cb;
    document.head.appendChild(tag);
  });
}

// ── Carica driver ─────────────────────────────────────────────
window.onload = async () => {
  let data;
  try {
    data = await apiCall('action=drivers');
  } catch(e) {
    document.getElementById('statusBox').innerHTML =
      '<div class="err">⚠️ Impossibile caricare i driver.<br>Controlla la connessione e ricarica.</div>';
    return;
  }

  if (!data.drivers || !data.drivers.length) {
    document.getElementById('statusBox').innerHTML =
      '<div class="err">Nessun driver trovato nel foglio.</div>';
    return;
  }

  const drivers = data.drivers;
  document.getElementById('subtitleCount').textContent =
    drivers.length + ' driver trovati — pronti per la stampa';

  const grid = document.getElementById('grid');
  grid.style.display = 'grid';
  document.getElementById('statusBox').style.display = 'none';

  drivers.forEach(d => {
    const url  = GIRO_URL + '?driver=' + encodeURIComponent(d.id);
    const card = document.createElement('div');
    card.className = 'qr-card';

    const qrWrap = document.createElement('div');
    qrWrap.className = 'qr-canvas';

    // Nomi: "COGNOME Nome" → mostra su due righe se possibile
    const parts   = (d.nome || d.id).trim().split(/\s+/);
    const upper   = parts.filter(p => p === p.toUpperCase() && p.length > 1);
    const cognome = upper.length ? upper.join(' ') : parts[0];
    const nome    = parts.filter(p => !upper.includes(p)).join(' ');

    card.innerHTML = `
      <div class="qr-id">ID: ${d.id}</div>
    `;
    card.appendChild(qrWrap);
    card.innerHTML += `
      <div class="qr-name">${cognome}${nome ? '<br><span style="font-weight:300;font-size:.85rem">' + nome + '</span>' : ''}</div>
      <div class="qr-url">${url}</div>
    `;

    // Reinserisci qrWrap (innerHTML l'ha perso)
    const nameDiv = card.querySelector('.qr-name');
    card.insertBefore(qrWrap, nameDiv);

    grid.appendChild(card);

    // Genera QR
    new QRCode(qrWrap, {
      text:           url,
      width:          160,
      height:         160,
      colorDark:      '#0a0f1e',
      colorLight:     '#ffffff',
      correctLevel:   QRCode.CorrectLevel.H
    });
  });
};
</script>
</body>
</html>
